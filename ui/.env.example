# BOB Camera UI Environment Configuration
# These variables are embedded at build time by Vite

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# API Base URL (relative or absolute)
# Used for all REST API calls
VITE_API_BASE_URL=/api

# WebSocket Base URL
# Used for telemetry, events, and logs streaming
VITE_WS_BASE_URL=ws://localhost:8080/ws

# ROS2 WebSocket URL (rosbridge)
# Only used if VITE_STREAM_PROTOCOL=ros2
VITE_ROS2_WS_URL=ws://localhost:9090

# ============================================================================
# VIDEO STREAM CONFIGURATION
# ============================================================================

# Video Stream Protocol: ros2 | hls | mjpeg | none
VITE_STREAM_PROTOCOL=ros2

# Stream URL (if different from API base)
VITE_STREAM_URL=/stream

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable mock mode for development without backend
VITE_MOCK_MODE=false

# Recording playback feature
VITE_ENABLE_RECORDINGS=true

# System metrics display (CPU, GPU, memory)
VITE_ENABLE_SYSTEM_METRICS=true

# Live logs feature
VITE_ENABLE_LOGS=true

# ============================================================================
# UI CONFIGURATION
# ============================================================================

# Application title (shown in header)
VITE_APP_TITLE=BOB Camera System

# Max detections to keep in memory buffer
VITE_MAX_DETECTIONS_BUFFER=1000

# Health check interval (ms)
VITE_HEALTH_CHECK_INTERVAL=10000

# ============================================================================
# BUILD & DEPLOYMENT
# ============================================================================

# Enable debug mode (verbose logging)
VITE_DEBUG=false

# NOTE: GIT_COMMIT is injected by Docker build process
# Used for version display in UI
# Priority:
#   1. Passed via docker build --build-arg GIT_COMMIT=<hash>
#   2. Detected from local git repo (npm run build)
#   3. Falls back to 'unknown' (expected in Docker builds without .git)